<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude encrypted DB (key is device-bound; backup would be unrestorable) -->
        <exclude domain="database" path="vault.db" />
        <exclude domain="database" path="vault.db-wal" />
        <exclude domain="database" path="vault.db-shm" />
        <!-- Exclude the EncryptedSharedPreferences file that holds the DB passphrase -->
        <exclude domain="sharedpref" path="vault_key_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="vault.db" />
        <exclude domain="database" path="vault.db-wal" />
        <exclude domain="database" path="vault.db-shm" />
        <exclude domain="sharedpref" path="vault_key_prefs.xml" />
    </device-transfer>
</data-extraction-rules>